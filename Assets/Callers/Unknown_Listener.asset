  ringSFX: {fileID: 0}
  voiceSFX: {fileID: 0}
  causesScreenFlicker: 0
  dialogueVariations:
  - lines:
    - '"Hello... it''s so nice to hear another human voice."'
    - '"It gets very quiet in my building. Do you work alone at this hour?"'
    - '"Are there... windows in your office?"'
    - '"I''d like to know exactly where you are sitting."'
  - lines:
    - '"I have a question about the software..."'
    - '"But first, can you hear that tapping sound?"'
    - '"It sounds like it''s coming from inside the walls of your booth."'
    - '"Put your ear against the glass."'
  - lines:
    - '"Thank you for answering. My name is... well, it doesn''t matter."'
    - '"I''ve been watching the streetlights flicker outside."'
    - '"I''m looking up at a very tall corporate building..."'
    - '"Which floor are you on?"'
  - lines:
    - '"Are there... windows in your office?"'
