  m_Name: Unknown_Listener
  m_EditorClassIdentifier: Assembly-CSharp::CallerData
  canMaskCallerID: 1
  callerName: Unknown
  callerNumber: 000-0000
  typeOfCaller: 3
  spawnWeight: 4
