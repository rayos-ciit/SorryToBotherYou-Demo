  monsterSprite: {fileID: -1846702766222976758, guid: 4c3c2dca5f6e2744e8f985a4a85a0daf, type: 3}
  dialogueVariations:
  - lines:
    - '"Finally! Do you have any idea how long I''ve been waiting to get through?!"'
    - '"I demand to speak to your shift supervisor immediately."'
    - '"Actually, forget it. You people are completely useless. Cancel my account!"'
  - lines:
    - '"Look, I have exactly two minutes before my train gets here so type fast."'
    - '"Just confirm that my payment went through. Did it?"'
    - '"Good. That''s all I needed. Send me the email receipt."'
  - lines:
    - '"This is the third time I''ve had to call this week!"'
    - '"Every time I call, I get put on hold and then mysteriously disconnected."'
    - '"Make sure this ticket is marked as resolved, or I''m calling the Better Business
      Bureau!"'
